<launch>
    <!-- 启动 rosbridge -->
    <include file="$(find rosbridge_server)/launch/rosbridge_websocket.launch" />

    <!-- TF2 Web Repulisher -->
    <node name="tf2_web_republisher"
          pkg="tf2_web_republisher"
          type="tf2_web_republisher"
          output="log" />

    <!-- Scepter 相机 -->
    <include file="$(find ScepterROS)/launch/scepter_camera.launch" />

    <!-- 自定义话题转发节点 -->
    <node name="topicTransNode"
          pkg="chassis_ctrl"
          type="topictransNode"
          output="log" />

    <node name="system_log_mux"
          pkg="chassis_ctrl"
          type="system_log_mux.py"
          output="log">
        <param name="ros_log_topic" value="/rosout_agg" />
        <param name="total_topic" value="/system_log/all" />
        <param name="stdout_poll_hz" value="2.0" />
        <param name="stdout_tail_bytes" value="4096" />
    </node>
</launch>
