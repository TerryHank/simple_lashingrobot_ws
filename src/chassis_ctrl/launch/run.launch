<launch>
    <node name="suoquNode" pkg="chassis_ctrl" type="suoquNode"  output="log"></node>
    <node name="moduanNode" pkg="chassis_ctrl" type="moduanNode"  output="log" ></node>
    <node name="gripper_tf_broadcaster"
          pkg="chassis_ctrl"
          type="gripper_tf_broadcaster.py"
          output="log">
        <param name="config_path" value="$(find chassis_ctrl)/config/gripper_tf.yaml" />
        <param name="publish_rate_hz" value="30.0" />
    </node>
    <node name="pointAINode" pkg="chassis_ctrl" type="pointAI.py"  output="log">
        <env name="ROSCONSOLE_FORMAT" value="[${severity}] ${message}" />
    </node> 
    <node name="stable_point_tf_broadcaster"
          pkg="chassis_ctrl"
          type="stable_point_tf_broadcaster.py"
          output="log">
        <param name="stable_frame_count" value="2" />
        <param name="stable_z_tolerance_mm" value="4.0" />
        <param name="publish_rate_hz" value="20.0" />
    </node>
</launch>
