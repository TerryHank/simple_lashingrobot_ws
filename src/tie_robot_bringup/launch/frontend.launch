<launch>
    <arg name="start_workspace_picker_web" default="true" />
    <arg name="auto_open_workspace_picker" default="false" />
    <arg name="workspace_picker_port" default="8080" />
    <arg name="browser_host" default="127.0.0.1" />

    <node if="$(arg start_workspace_picker_web)"
          name="workspace_picker_web_server"
          pkg="tie_robot_web"
          type="workspace_picker_web_server.py"
          output="log"
          respawn="true"
          respawn_delay="2.0">
        <param name="port" value="$(arg workspace_picker_port)" />
        <param name="browser_host" value="$(arg browser_host)" />
    </node>

    <node if="$(arg auto_open_workspace_picker)"
          name="workspace_picker_web_open"
          pkg="tie_robot_web"
          type="workspace_picker_web_open.py"
          output="log">
        <param name="port" value="$(arg workspace_picker_port)" />
        <param name="browser_host" value="$(arg browser_host)" />
        <param name="wait_timeout_sec" value="8.0" />
        <param name="open_delay_sec" value="1.0" />
    </node>
</launch>
