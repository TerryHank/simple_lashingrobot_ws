<launch>
    <!-- Web Action/Service 桥接节点：话题由前端直接连接驱动层/算法层 -->
    <node name="web_action_bridge_node"
          pkg="tie_robot_web"
          type="web_action_bridge_node"
          output="log"
          respawn="true"
          respawn_delay="2.0" />

    <node name="system_log_mux"
          pkg="tie_robot_web"
          type="system_log_mux.py"
          output="log"
          respawn="true"
          respawn_delay="2.0">
        <param name="ros_log_topic" value="/rosout_agg" />
        <param name="total_topic" value="/system_log/all" />
        <param name="stdout_poll_hz" value="2.0" />
        <param name="stdout_tail_bytes" value="4096" />
    </node>
</launch>
