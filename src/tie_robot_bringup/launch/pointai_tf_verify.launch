<launch>
    <arg name="tf_config_path" default="$(find tie_robot_perception)/config/gripper_tf.yaml" />
    <arg name="tf_publish_rate_hz" default="30.0" />

    <node name="gripper_tf_broadcaster"
          pkg="tie_robot_perception"
          type="gripper_tf_broadcaster.py"
          output="log">
        <param name="config_path" value="$(arg tf_config_path)" />
        <param name="publish_rate_hz" value="$(arg tf_publish_rate_hz)" />
    </node>

    <node name="pointAINode"
          pkg="tie_robot_perception"
          type="pointai_node.py"
          output="log">
        <env name="ROSCONSOLE_FORMAT" value="[${severity}] ${message}" />
    </node>
</launch>
