[Unit]
Description=Tie Robot ROS backend stack
Wants=network-online.target tie-robot-rosbridge.service
After=network-online.target tie-robot-rosbridge.service

[Service]
Type=simple
User=@USER@
WorkingDirectory=@WORKSPACE@
Environment=ROS_HOME=@WORKSPACE@/.ros
Environment=ROS_LOG_DIR=@WORKSPACE@/.ros/log
Environment=ROS_MASTER_URI=http://127.0.0.1:11311
ExecStartPre=/bin/mkdir -p @WORKSPACE@/.ros/log
ExecStartPre=/bin/bash -lc '@WORKSPACE@/src/tie_robot_bringup/tools/wait_for_ros_master.py --timeout-sec 30'
ExecStart=/bin/bash -lc 'source /opt/ros/noetic/setup.bash && source @WORKSPACE@/devel/setup.bash && exec roslaunch tie_robot_bringup run.launch'
Restart=on-failure
RestartSec=5
KillSignal=SIGINT
KillMode=control-group
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
