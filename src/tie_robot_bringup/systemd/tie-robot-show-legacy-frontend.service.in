[Unit]
Description=Tie Robot legacy show frontend
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
User=@USER@
WorkingDirectory=@LEGACY_DIST@
ExecStart=/bin/bash -lc 'exec python3 -m http.server 5173 --bind 0.0.0.0 --directory @LEGACY_DIST@'
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
